{
  "name": "waywatch-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "seed": "ts-node src/seed.ts",
    "gen:jwt-secret": "node -e \"console.log(require('crypto').randomBytes(48).toString('hex'))\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev:redis": "docker run --rm -p 6379:6379 --name cqbp-redis redis:7-alpine",
    "migrate:refresh-tokens": "ts-node src/scripts/migrate_refresh_tokens.ts",
    "test": "jest --runInBand --detectOpenHandles --testPathPattern src",
    "test:unit": "jest --config jest.config.ts --testPathPattern src/__tests__ --runInBand --detectOpenHandles",
    "aggregate:once": "ts-node src/scripts/aggregator.ts --once",
    "aggregate:cron": "ts-node src/scripts/aggregator.ts",
    "geojson:validate": "ts-node src/scripts/validate_geojson.ts --",
    "geojson:ors": "ts-node src/scripts/ors_generate_route_geojson.ts --"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-mongo-sanitize": "^2.2.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.8.1",
    "ms": "^2.1.3",
    "node-cron": "^3.0.3",
    "rate-limiter-flexible": "^9.0.1",
    "winston": "^3.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.30",
    "@types/node-cron": "^2.0.8",
    "@types/p-limit": "^2.1.0",
    "@types/supertest": "^6.0.3",
    "jest": "^29.6.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testTimeout": 20000
  }
}
